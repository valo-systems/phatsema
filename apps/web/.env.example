# Frontend environment (Vite). Values are baked at build time.
# Base path of the API, same origin in production.
VITE_API_BASE=/api/v1
# Marks the build as a demo build (shows demo banner and persona quick-select).
VITE_DEMO_MODE=true
# Application release identifier shown in the About panel.
VITE_APP_VERSION=1.0.0-demo
